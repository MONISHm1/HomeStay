<!DOCTYPE html>
<html>
<head>
    <title>HomeStay</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<h1>🏡 HomeStay Listings</h1>

<a href="/listings/new">➕ Add New Listing</a>

<% listings.forEach(listing => { %>
    <div class="card">
        <h2><%= listing.title %></h2>
        <p>📍 <%= listing.location %></p>
        <p>💰 ₹<%= listing.price %></p>

        <a href="/listings/<%= listing._id %>">View</a>
    </div>
<% }) %>

<form action="/listings" method="POST" enctype="multipart/form-data">
    <input name="title" placeholder="Title"><br><br>
    <input name="location" placeholder="Location"><br><br>
    <input name="price" placeholder="Price"><br><br>

    <input type="file" name="image"><br><br>

    <button>Add</button>
</form>

</body>
</html>