<% layout("layouts/boilerplate") %>

<link rel="stylesheet" href="/css/editProfile.css">

<div class="edit-profile-page">
    <div class="edit-profile-card">
        <div class="edit-header">
            <h1>Edit Profile</h1>
            <p>Keep your profile updated so guests and hosts can know you better.</p>
        </div>

        <form action="/profile?_method=PUT" method="POST" enctype="multipart/form-data" class="needs-validation" novalidate>

            <div class="profile-image-section">
                <% if(user.avatar && user.avatar.filename !== "default-avatar"){ %>
                    <img src="<%= user.avatar.url %>" id="previewImage" class="profile-preview">
                <% } else { %>
                    <div class="default-avatar" id="previewAvatar">
                        <%= user.username.charAt(0).toUpperCase() %>
                    </div>
                <% } %>

                <label class="upload-btn">
                    Change Photo
                    <input type="file" name="avatar" id="avatarInput" accept="image/*" hidden>
                </label>
            </div>

            <div class="form-group">
                <label>Username</label>
                <input type="text" class="form-control" value="<%= user.username %>" readonly>
                <small class="text-muted">Username cannot be changed.</small>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" class="form-control" value="<%= user.email %>" required>
            </div>

            <div class="form-group">
                <label>Phone</label>
                <input type="text" name="phone" class="form-control" value="<%= user.phone %>">
            </div>

            <div class="form-group">
                <label>Country</label>
                <input type="text" name="country" class="form-control" value="<%= user.country %>">
            </div>

            <div class="form-group">
                <label>Bio</label>
                <textarea name="bio" rows="5" class="form-control"><%= user.bio %></textarea>
            </div>

            <button class="save-btn">Save Changes</button>

        </form>
    </div>
</div>

<script>
const avatarInput = document.getElementById("avatarInput");

avatarInput.addEventListener("change", function () {
    const file = this.files[0];
    if (!file) return;

    const reader = new FileReader();

    reader.onload = function (e) {
        const old = document.getElementById("previewAvatar");

        if (old) {
            const img = document.createElement("img");
            img.src = e.target.result;
            img.id = "previewImage";
            img.className = "profile-preview";
            old.replaceWith(img);
        } else {
            document.getElementById("previewImage").src = e.target.result;
        }
    };

    reader.readAsDataURL(file);
});
</script>